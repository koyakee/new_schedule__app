<h3>予定の新規追加</h3>

<%= render "shared/error", obj: @post %>

<%= form_with model: @post do |f| %>
    <table>
        <tr>
            <th><%= f.label :title ,"タイトル" %></th>
            <td><%= f.text_field :title %></td>
        </tr>

        <tr>
            <th><%= f.label :startDate ,"開始日" %></th>
            <td><%= f.date_field :startDate %></td>
        </tr>

        <tr>
            <th><%= f.label :endDate ,"終了日" %></th>
            <td><%= f.date_field :endDate %></td>
        </tr>

        <tr>
            <th><%= f.label :allDay ,"終日の場合はチェックを入れます" %></th>
            <td><%= f.check_box :allDay %></td>
        </tr>

        <tr>
            <th><%= f.label :scheduleMemo ,"スケジュールメモ" %></th>
            <td><%= f.text_area :scheduleMemo %></td>
        </tr>
    </table>

    <div>
        <ul>
            <li><%= f.submit "保存" %></li>
            <li><%= link_to "キャンセル", :posts %></li>
        </ul>
    </div>
<% end %>